#pragma code_page(65001)
#include "resource.h"
#include <windows.h>
#include <commctrl.h>

// ── 로그인 ─────────────────────────────────────────────────────
IDD_LOGIN DIALOGEX 0, 0, 260, 180
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "StudySync - Login"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "StudySync",       IDC_STATIC_TITLE,    10,  10, 240, 18, SS_CENTER
    LTEXT           "Email",           IDC_STATIC_EMAIL,    20,  45,  60, 12
    EDITTEXT                          IDC_EDIT_EMAIL,      85,  43, 155, 14, ES_AUTOHSCROLL
    LTEXT           "Password",        IDC_STATIC_PASSWORD, 20,  68,  60, 12
    EDITTEXT                          IDC_EDIT_PASSWORD,   85,  66, 155, 14, ES_AUTOHSCROLL | ES_PASSWORD
    LTEXT           "",               IDC_STATIC_MSG,      20, 100, 220, 12, SS_LEFT
    PUSHBUTTON      "Login",          IDOK,                55, 120,  65, 18
    PUSHBUTTON      "Register",       IDC_BTN_REGISTER,   135, 120,  65, 18
    PUSHBUTTON      "Cancel",         IDCANCEL,            55, 148,  65, 18
END

// ── 회원가입 ───────────────────────────────────────────────────
IDD_REGISTER DIALOGEX 0, 0, 260, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "StudySync - Register"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "Name",            IDC_STATIC_NAME,     20,  20,  60, 12
    EDITTEXT                          IDC_EDIT_NAME,       85,  18, 155, 14, ES_AUTOHSCROLL
    LTEXT           "Email",           IDC_STATIC_EMAIL,    20,  44,  60, 12
    EDITTEXT                          IDC_EDIT_EMAIL2,     85,  42, 155, 14, ES_AUTOHSCROLL
    LTEXT           "Password",        IDC_STATIC_PASSWORD, 20,  68,  60, 12
    EDITTEXT                          IDC_EDIT_PASSWORD2,  85,  66, 155, 14, ES_AUTOHSCROLL | ES_PASSWORD
    LTEXT           "Confirm",         IDC_STATIC,          20,  92,  60, 12
    EDITTEXT                          IDC_EDIT_PASSWORD_CONFIRM, 85, 90, 155, 14, ES_AUTOHSCROLL | ES_PASSWORD
    LTEXT           "",               IDC_STATIC_MSG2,     20, 118, 220, 12, SS_LEFT
    PUSHBUTTON      "Register",       IDOK,                80, 140,  65, 18
    PUSHBUTTON      "Cancel",         IDCANCEL,           160, 140,  65, 18
END

// ── FPS 설정 ──────────────────────────────────────────────────
IDD_FPS DIALOGEX 0, 0, 200, 90
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "카메라 FPS 설정"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "카메라 FPS를 입력하세요 (1 ~ 120):",
                    IDC_STATIC,          10, 12, 180, 12
    EDITTEXT        IDC_EDIT_FPS,        10, 28, 180, 14, ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON      "확인",             IDOK,     36, 56, 55, 18
    PUSHBUTTON      "취소",             IDCANCEL, 108, 56, 55, 18
END

// ── 복기 화면 ─────────────────────────────────────────────────
//  480 x 370 DLU (약 720 x 555 px @ 96dpi)
//
//  [헤더 문구]
//  ┌──────────────────────────────────────┐  ListCtrl (report)
//  │ 시각     │ 판정     │ 신뢰도 │ 피드백 │
//  │ 14:30:05 │ 졸음 감지 │ ★★☆  │ -     │  ← confidence<0.70  노란 배경
//  │ 14:45:12 │ 자세 불량 │ ★★★  │ -     │  ← 0.70~0.85
//  │ 15:02:33 │ 졸음 감지 │ ★★★★ │ 없음  │  ← ≥0.85, 버튼 없음
//  └──────────────────────────────────────┘
//  이 판정이 맞나요?   [✓ 맞아요]  [✗ 틀렸어요]
//                                         [닫기]

IDD_REVIEW DIALOGEX 0, 0, 480, 370
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "학습 복기"
FONT 9, "Segoe UI"
BEGIN
    // 헤더 문구
    LTEXT           "",
                    IDC_STATIC_REVIEW_HEADER,  10,   8, 460, 14

    // 이벤트 목록 (SysListView32 = CListCtrl)
    CONTROL         "",
                    IDC_LIST_EVENTS,
                    "SysListView32",
                    LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | LVS_NOSORTHEADER | WS_BORDER | WS_TABSTOP,
                    10,  26, 460, 286

    // 피드백 패널 (하단)
    LTEXT           "이 판정이 맞나요?",
                    IDC_STATIC_QUESTION,       10, 322, 130, 14

    PUSHBUTTON      "✓  맞아요",
                    IDC_BTN_CORRECT,          148, 318,  80, 20

    PUSHBUTTON      "✗  틀렸어요",
                    IDC_BTN_WRONG,            236, 318,  80, 20

    // 피드백 완료 문구 (버튼 자리를 대체, 초기엔 숨김)
    LTEXT           "",
                    IDC_STATIC_FEEDBACK_DONE, 148, 322, 168, 14

    // 닫기
    PUSHBUTTON      "닫기",
                    IDCANCEL,                 396, 344,  74, 18
END
